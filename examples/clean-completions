#!/usr/bin/env bash
set -euo pipefail

# Remove all bash completion files generated by options.bash.
#
# Usage:
#   clean-completions          — list files that would be removed (dry run)
#   clean-completions remove   — remove the files
#
# Identifies generated files by the signature comment:
#   # options.bash-completion v<N>

COMP_DIR="${HOME}/.local/share/bash-completion/completions"

if [[ ! -d "$COMP_DIR" ]]; then
  echo "No completion directory: $COMP_DIR"
  exit 0
fi

files=()
while IFS= read -r -d '' f; do
  files+=("$f")
done < <(grep -rl --null 'options\.bash-completion v' "$COMP_DIR" 2>/dev/null || true)

if [[ ${#files[@]} -eq 0 ]]; then
  echo "No options.bash completion files found in $COMP_DIR"
  exit 0
fi

if [[ "${1:-}" == "remove" ]]; then
  for f in "${files[@]}"; do
    rm -v "$f"
  done
  echo "Removed ${#files[@]} file(s). Reload your shell (exec bash) to apply."
else
  echo "Found ${#files[@]} options.bash completion file(s):"
  for f in "${files[@]}"; do
    echo "  $f"
  done
  echo ""
  echo "Run '$(basename "$0") remove' to delete them."
fi
